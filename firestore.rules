rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function getUserData() { 
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; 
    }
    function hasRole(role) { 
      return isSignedIn() && isEmailVerified() && getUserData().role == role; 
    }
    function isAdmin() { return hasRole('ADMIN'); }
    function isCommander() { return hasRole('COMMANDER'); }
    function isManager() { return hasRole('MANAGER'); }
    function isClerk() { return hasRole('CLERK'); }
    function isStaff() { return isAdmin() || isCommander() || isManager() || isClerk(); }
    
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Helpers ---
    function isValidProfile(data) {
      return data.fullName is string && data.fullName.size() > 0 && data.fullName.size() <= 200
          && data.idNumber is string && data.idNumber.size() >= 9 && data.idNumber.size() <= 15
          && data.type in ['QUAN_NHAN', 'SI_QUAN_DU_BI', 'CONG_DAN_NVQS'];
    }

    // --- Collection Rules ---

    match /users/{userId} {
      // Users can read their own settings
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // Only admins can update roles/permissions
      allow write: if isAdmin() && userId is string;
    }

    match /profiles/{profileId} {
      allow read: if isSignedIn() && isEmailVerified();
      
      allow create: if isStaff() && isValidProfile(incoming()) && isValidId(profileId) && (
        incoming().createdBy == request.auth.uid &&
        incoming().createdAt == request.time
      );

      allow update: if isStaff() && isValidProfile(incoming()) && (
        // Action: General update
        (incoming().diff(existing()).affectedKeys().hasAny(['fullName', 'alias', 'birthDate', 'gender', 'idNumber', 'idIssueDate', 'idIssuePlace', 'ethnicity', 'religion', 'nationality', 'bloodType', 'height', 'weight', 'maritalStatus', 'phone', 'email', 'militaryCode', 'type', 'address', 'militaryInfo', 'health', 'education', 'family', 'updatedAt'])) &&
        incoming().updatedAt == request.time &&
        incoming().createdAt == existing().createdAt &&
        incoming().createdBy == existing().createdBy
      );

      allow delete: if isAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && isEmailVerified() && logId is string;
    }
  }
}
